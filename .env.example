# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Tencent Cloud API Credentials ─────────────────────────────────────────────
# Get from: https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=your-secret-id-here
TENCENTCLOUD_SECRET_KEY=your-secret-key-here

# ── Kubernetes Authentication (choose one approach) ───────────────────────────

# Approach 1 (Recommended): KUBECONFIG file path
# Download kubeconfig from TKE Console → Cluster → Basic Info → Kubeconfig
# KUBECONFIG=/path/to/cls-5mchtmid-config.yaml

# Approach 2: Individual TLS environment variables
# K8S_SERVER=https://<api-server-ip>
# K8S_CA_DATA=<base64-encoded-ca-certificate>
# K8S_CERT_DATA=<base64-encoded-client-certificate>
# K8S_KEY_DATA=<base64-encoded-client-private-key>
